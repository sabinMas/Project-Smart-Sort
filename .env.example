# ============================================
# Box Smart Inbox - Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# === EMAIL INGESTION (Domain 1) ===
SENDGRID_API_KEY=sg_test_abc123xyz_replace_with_your_key
SENDGRID_VERIFY_TOKEN=your_verify_token_here
SENDGRID_INBOUND_URL=https://yourngrok.ngrok.app/webhooks/email

# Alternative to SendGrid (if using Postmark)
POSTMARK_API_KEY=your_postmark_key_here
POSTMARK_INBOUND_URL=https://yourngrok.ngrok.app/webhooks/email

# === AI CLASSIFICATION (Domain 2) ===
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=your_cerebras_key_here
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# === BOX INTEGRATION (Domain 3) ===
BOX_CLIENT_ID=your_box_client_id
BOX_CLIENT_SECRET=your_box_client_secret
BOX_ENTERPRISE_ID=your_enterprise_id
BOX_DEMO_FOLDER_ID=12345

# === SHARED CONFIGURATION ===
ENVIRONMENT=development
LOG_LEVEL=DEBUG
WEBHOOK_PRIMARY_KEY=box_webhook_primary_key
WEBHOOK_SECONDARY_KEY=box_webhook_secondary_key

# === NOTIFICATIONS (Domain 3) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# === OPTIONAL: REDIS (for async queue) ===
REDIS_URL=redis://localhost:6379
USE_ASYNC_QUEUE=false

# === DEMO MODE ===
DEMO_MODE=false

# === INTERNAL SETTINGS ===
API_PORT=8000
API_HOST=0.0.0.0
