{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rootDirectory": "box-extension",
  "env": {
    "VITE_ENVIRONMENT": "production"
  },
  "routes": [
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
